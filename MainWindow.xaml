<Window x:Class="Jarvis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="J.A.R.V.I.S"
        Height="850"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#0B0F19">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- HEADER -->

        <Grid Grid.Row="0" Grid.ColumnSpan="3">

            <TextBlock Text="J.A.R.V.I.S"
                       FontSize="28"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center">
                <TextBlock.Foreground>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FF848484"/>
                        <GradientStop Color="#8EFFB68B" Offset="0.393"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
            </TextBlock>

            <Border Width="220"
                    Height="45"
                    HorizontalAlignment="Center"
                    CornerRadius="20"
                    Background="#121826"
                    BorderBrush="#00C8FF"
                    BorderThickness="1">

                <TextBlock Text="● Система активна"
                           Foreground="#00FF88"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

        </Grid>

        <!-- LEFT PANEL -->

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#121826"
                CornerRadius="20"
                Margin="0,10,10,10">

            <StackPanel Margin="15">

                <TextBlock Text="Швидкі дії"
                           FontSize="22"
                           Foreground="White"
                           Margin="0,0,0,20"/>

                <Button Content="📄 Відкрити блокнот"
                        Height="60"
                        Margin="0,0,0,10" Foreground="White" Background="#FF0E0E0E"/>

                <Button Content="🧮 Відкрити калькулятор"
                        Height="60"
                        Margin="0,0,0,10" Foreground="White" Background="#FF0E0E0E"/>

                <Button Content="🌐 Відкрити браузер"
                        Height="60"
                        Margin="0,0,0,10" Background="#FF0E0E0E" Foreground="White"/>

                <Button Content="🕒 Поточний час"
                        Height="60"
                        Margin="0,0,0,10" Background="#FF0E0E0E" Foreground="White"/>

                <Button Content="🗑 Очистити журнал"
                        Height="60" Background="#FF0E0E0E" Foreground="White"/>

            </StackPanel>

        </Border>

        <!-- CENTER -->

        <Grid Grid.Row="1"
              Grid.Column="1">

            <Border Background="#121826"
                    CornerRadius="25"
                    Margin="10">

                <Grid>

                    <!-- AI Core -->

                    <Ellipse x:Name="OuterRing"
                              Width="320"
                    Height="320"
                    Stroke="#00C8FF"
                     StrokeThickness="4"
                     HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

                    <Ellipse Width="260"
                             Height="260"
                             Stroke="#29FFE6"
                             StrokeThickness="2"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>

                    <Ellipse Width="180"
                             Height="180"
                             Fill="#1A2438"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"/>

                    <TextBlock Text="🎤"
                               FontSize="80"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <StackPanel VerticalAlignment="Bottom"
                                Margin="0,0,0,21">

                        <TextBlock Text="Слухаю..."
                                   Foreground="White"
                                   FontSize="42"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="Скажіть команду після сигналу"
                                   Foreground="#AAAAAA"
                                   FontSize="18"
                                   HorizontalAlignment="Center" RenderTransformOrigin="0.497,0"/>

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

        <!-- RIGHT PANEL -->

        <Border Grid.Row="1"
                Grid.Column="2"
                Background="#121826"
                CornerRadius="20"
                Margin="10">

            <StackPanel Margin="15">

                <TextBlock Text="Журнал подій"
                           FontSize="22"
                           Foreground="White"
                           Margin="0,0,0,20"/>

                <ListBox Background="Transparent"
                         BorderThickness="0"
                         Foreground="White">

                    <ListBoxItem>18:42 - Команда отримана</ListBoxItem>
                    <ListBoxItem>18:42 - Відкрито калькулятор</ListBoxItem>
                    <ListBoxItem>18:43 - Запит часу</ListBoxItem>
                    <ListBoxItem>18:44 - Відкрито браузер</ListBoxItem>

                </ListBox>

            </StackPanel>

        </Border>

        <!-- BOTTOM PANEL -->

        <Border Grid.Row="2"
                Grid.ColumnSpan="3"
                Background="#121826"
                CornerRadius="25"
                Margin="0,10,0,0">

            <Grid Margin="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="MicButton"
        Width="60"
        Height="60"
        Background="#FF0E0E0E"
        Foreground="White"
        Content="🎤">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                    CornerRadius="30">
                                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                </Button>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center">

                    <TextBlock Text="Готовий прийняти команду..."
                               Foreground="White"
                               FontSize="22"/>

                    <TextBlock Text="Скажіть або натисніть мікрофон"
                               Foreground="#999999"/>

                </StackPanel>

                <Button Grid.Column="2"
        Width="60"
        Height="60"
        Background="#FF0E0E0E"
        Foreground="White"
        Content="➜">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">

                            <Border Background="{TemplateBinding Background}"
                    CornerRadius="30">

                                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>

                            </Border>

                        </ControlTemplate>
                    </Button.Template>

                </Button>


            </Grid>

        </Border>

    </Grid>

</Window>