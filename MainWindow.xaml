<Window x:Class="Jarvis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Desktop Assistant"
        Height="900" Width="1440"
        WindowStartupLocation="CenterScreen"
        Background="#080C14"
        FontFamily="Segoe UI"
        WindowStyle="None" 
        AllowsTransparency="True">

    <Window.Resources>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="12" BorderBrush="#1A2438" BorderThickness="1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A2438"/>
                                <Setter Property="BorderBrush" Value="#00C8FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowControlButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7D8A9F"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A2438"/>
                                <Setter Property="Foreground" Value="#00C8FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowCloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#7D8A9F"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="LogItemTemplate">
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>

                <Border Width="32" Height="32" CornerRadius="8" Background="#1A2438" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding Icon}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{Binding IconColor}" FontSize="16"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Subtitle}" Foreground="#7D8A9F" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>

                <TextBlock Grid.Column="2" Text="{Binding Time}" Foreground="#7D8A9F" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,0,0"/>
            </Grid>
        </DataTemplate>

    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,15" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="40" Height="40" CornerRadius="10" Background="#0061FF">
                    <TextBlock Text="🛡️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="J.A.R.V.I.S" Foreground="White" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Ваш голосовий помічник" Foreground="#7D8A9F" FontSize="13"/>
                </StackPanel>
            </StackPanel>

            <Border Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" 
                    Background="#121826" CornerRadius="15" BorderBrush="#1A2438" BorderThickness="1" Padding="15,8">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="#00FF88" Margin="0,0,10,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#00FF88" BlurRadius="10" ShadowDepth="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <TextBlock x:Name="StatusText" Text="Система активна" Foreground="#B0B8C5" FontSize="14"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right">

                <TextBlock Text="🕒" FontSize="24" Foreground="#7D8A9F" VerticalAlignment="Center" Margin="0,5,10,0"/>
                <StackPanel VerticalAlignment="Center" Margin="0,5,20,0">
                    <TextBlock Text="18:42" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Text="25 травня 2026" Foreground="#7D8A9F" FontSize="12"/>
                </StackPanel>
                <Button Content="⚙️" FontSize="20" Background="Transparent" Foreground="#7D8A9F" BorderThickness="0" Margin="0,5,30,0" FocusVisualStyle="{x:Null}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Content="—" Style="{StaticResource WindowControlButton}" Click="BtnMinimize_Click"/>
                    <Button Content="🗖" Style="{StaticResource WindowControlButton}" Click="BtnMaximize_Click"/>
                    <Button Content="✕" Style="{StaticResource WindowCloseButton}" Click="BtnClose_Click"/>
                </StackPanel>

            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#101520" CornerRadius="15" Padding="20">
                <StackPanel>
                    <TextBlock Text="Швидкі дії" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>

                    <Button Style="{StaticResource MenuButtonStyle}" x:Name="BtnOpenNotepad" Click="BtnOpenNotepad_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" CornerRadius="8" Background="#1A2438">
                                <TextBlock Text="📝" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Відкрити блокнот" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="Запуск Notepad" Foreground="#7D8A9F" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="›" Foreground="#7D8A9F" FontSize="24" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource MenuButtonStyle}" x:Name="BtnOpenCalc" Click="BtnOpenCalc_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" CornerRadius="8" Background="#1A2438">
                                <TextBlock Text="🧮" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Відкрити калькулятор" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="Запуск Calculator" Foreground="#7D8A9F" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="›" Foreground="#7D8A9F" FontSize="24" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource MenuButtonStyle}" x:Name="BtnOpenBrowser" Click="BtnOpenBrowser_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" CornerRadius="8" Background="#1A2438">
                                <TextBlock Text="🌐" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Відкрити браузер" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="Запуск Chrome" Foreground="#7D8A9F" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="›" Foreground="#7D8A9F" FontSize="24" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button Style="{StaticResource MenuButtonStyle}" x:Name="BtnClearLog" Click="BtnClearLog_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="40" Height="40" CornerRadius="8" Background="#1A2438">
                                <TextBlock Text="🗑️" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Очистити журнал" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Text="Видалити всі записи" Foreground="#7D8A9F" FontSize="12"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="›" Foreground="#7D8A9F" FontSize="24" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="#101520" CornerRadius="15" Padding="20" Margin="0,15,0,0">
                <StackPanel>
                    <TextBlock Text="Стан системи" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💻" Foreground="#00C8FF" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="CPU" Foreground="#7D8A9F" FontSize="12"/>
                                    <TextBlock Text="18%" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🗄️" Foreground="#29FFE6" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock Text="RAM" Foreground="#7D8A9F" FontSize="12"/>
                                    <TextBlock Text="42%" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1" Grid.Column="1" Background="#101520" CornerRadius="20" Margin="0,0,15,0">
            <Grid>
                <Ellipse Width="450" Height="450" Stroke="#00C8FF" StrokeThickness="1" Opacity="0.1" StrokeDashArray="4 4" Margin="112,89,113,125"/>
                <Ellipse Width="380" Height="380" Stroke="#00C8FF" StrokeThickness="2" Opacity="0.3" Margin="148,124,147,160"/>

                <Ellipse x:Name="OuterRing" Width="280" Height="280" Stroke="#0061FF" StrokeThickness="4" Opacity="0.8" Margin="198,168,197,216">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#0061FF" BlurRadius="20" ShadowDepth="0"/>
                    </Ellipse.Effect>
                </Ellipse>

                <Ellipse Width="220" Height="220" Fill="#00183A" Stroke="#00C8FF" StrokeThickness="4" Margin="228,200,227,244">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#00C8FF" BlurRadius="40" ShadowDepth="0"/>
                    </Ellipse.Effect>
                </Ellipse>

                <TextBlock x:Name="CoreIcon" Text="🎙️" FontSize="80" HorizontalAlignment="Center" VerticalAlignment="Top" Foreground="White" Margin="0,251,0,0">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="White" BlurRadius="10" ShadowDepth="0"/>
                    </TextBlock.Effect>
                </TextBlock>

                <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,40">
                    <TextBlock x:Name="AiStateText" Text="Слухаю..." Foreground="White" FontSize="32" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="AiSubStateText" Text="Скажіть команду після сигналу" Foreground="#7D8A9F" FontSize="16" HorizontalAlignment="Center" Margin="0,5,0,4"/>

                    <Button Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" Cursor="Hand" FocusVisualStyle="{x:Null}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </ControlTemplate>
                        </Button.Template>
                        <Border Background="#1A2438" CornerRadius="15" Padding="15,8" Margin="0,0,0,-16">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✨" Foreground="#00C8FF" Margin="0,0,8,0"/>
                                <TextBlock Text="Натисніть для зупинки" Foreground="#B0B8C5" FontSize="13" Margin="0,0,0,-15"/>
                            </StackPanel>
                        </Border>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="2" Background="#101520" CornerRadius="20" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Журнал подій" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,20"/>

                <ListBox x:Name="LogListBox" Grid.Row="1" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Grid.ColumnSpan="3" Background="#101520" CornerRadius="20" Margin="0,15,0,0" Padding="20,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="60" Height="60" CornerRadius="15" Background="#1A2438">
                    <TextBlock Text="〰️〰️〰️" Foreground="#00C8FF" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" Width="60" Height="40"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                    <TextBlock x:Name="BottomMainPrompt" Text="Готовий прийняти команду..." Foreground="White" FontSize="20" FontWeight="SemiBold"/>
                    <TextBlock x:Name="BottomSubPrompt" Text="Скажіть або натисніть мікрофон" Foreground="#7D8A9F" FontSize="14" Margin="0,4,0,0"/>
                </StackPanel>

                <Button x:Name="MicButton" Click="MicButton_Click" Grid.Column="2" Width="65" Height="65" Background="Transparent" BorderThickness="0" Cursor="Hand" FocusVisualStyle="{x:Null}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </ControlTemplate>
                    </Button.Template>
                    <Grid>
                        <Ellipse Fill="#00C8FF">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#00C8FF" BlurRadius="15" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="🎙️" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Button>
            </Grid>
        </Border>

    </Grid>
</Window>