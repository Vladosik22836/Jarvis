<Window x:Class="Jarvis.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Boot" 
        WindowStyle="None" WindowState="Maximized" Background="Black"
        Loaded="Window_Loaded">

    <Grid>
        <StackPanel x:Name="SystemMessagesPanel" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="50" />

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <Grid Width="200" Height="200" Margin="0,0,0,30">
                <Ellipse x:Name="ReactorRing" Width="120" Height="120" Stroke="#29FFE6" StrokeThickness="2" Opacity="0">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#29FFE6" BlurRadius="20" ShadowDepth="0" />
                    </Ellipse.Effect>
                </Ellipse>

                <Ellipse x:Name="ReactorCore" Width="60" Height="60" Fill="#00C8FF" Opacity="0">
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#00C8FF" BlurRadius="40" ShadowDepth="0" />
                    </Ellipse.Effect>
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="CoreScale" ScaleX="1" ScaleY="1" CenterX="30" CenterY="30"/>
                    </Ellipse.RenderTransform>
                </Ellipse>
            </Grid>

            <TextBlock x:Name="TitleText" FontSize="64" Foreground="White" 
                       FontFamily="Consolas" HorizontalAlignment="Center" 
                       Height="80" Text="" />

        </StackPanel>
    </Grid>
</Window>